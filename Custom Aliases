# UNIVERSAL ALIASES
# Works on Bash, Zsh, and Fish. 

# File & Folder Management
alias list='ls -lah'
alias change='cd'
alias whereami='pwd'
alias copy='cp -ri'
alias move='mv -i'
alias delete='rm -i'
alias forcedelete='rm -rf'
alias makefile='touch'        # <--- Makes a blank file
alias makefolder='mkdir'      # <--- Makes a folder
alias show='cat'
alias editor='nano'
alias say='echo'

# System & Permissions
alias keep='sudo'
alias makeapp='chmod +x'
alias owner='chown'
alias clear='clear'
alias exit='exit'
alias whoami='whoami'
alias memory='free -m'
alias disk='df -h'
alias helpme='man'
alias mynames='alias'
alias now='date'
alias myname='hostname'
alias mycommands='alias'

# Navigation & Search
alias ..='cd ..'
alias ...='cd ../..'
alias back='cd -'
alias search='grep'
alias findfile='find . -name'

# Network
alias ip='ip addr 2>/dev/null || ifconfig'
alias sniff='ping -c 4'

